---
type Locale = "en" | "zh";

interface Props {
  locale?: Locale;
}

const locale: Locale = Astro.props.locale === "zh" ? "zh" : "en";

const i18n =
  locale === "zh"
    ? {
        backToDocs: "返回文档",
        pageTitle: "GPROXY 下载",
        pageDescription: "下载 release 与 staging 二进制，并校验 SHA256。",
        loadingManifests: "正在加载清单...",
        searchLabel: "搜索",
        searchPlaceholder: "gproxy-linux-x86_64.zip",
        platformLabel: "平台",
        allPlatforms: "全部平台",
        archLabel: "架构",
        allArch: "全部架构",
        detectedOs: "检测到系统",
        detectedArch: "检测到架构",
        runtimeTip: "建议先校验 SHA256 后再运行二进制。",
        recommendationTitle: "推荐下载",
        recommendationLoading: "正在根据设备环境匹配推荐包...",
        recommendationNone: "未找到匹配当前设备的构建包，请手动选择。",
        recommendationHint: "当前设备推荐：{asset}",
        recommendationRelease: "Release",
        recommendationStaging: "Staging",
        releaseTitle: "Release",
        stagingTitle: "Staging",
        tagLabel: "标签",
        assetsLabel: "文件数",
        assetHeader: "资产",
        downloadHeader: "下载",
        shaHeader: "SHA256",
        loadingRow: "加载中...",
        noAssets: "当前筛选条件下没有可用资产。",
        downloadBtn: "下载",
        shaBtn: "SHA256",
        recommendedBadge: "推荐",
        loadedStatus: "已从 {base} 加载 release 与 staging 清单。",
        partialStatus: "部分清单加载失败，请检查网络或发布状态。",
        failedStatus: "加载失败：{error}",
      }
    : {
        backToDocs: "Back to docs",
        pageTitle: "GPROXY Downloads",
        pageDescription: "Download release and staging binaries with checksum verification.",
        loadingManifests: "Loading manifests...",
        searchLabel: "Search",
        searchPlaceholder: "gproxy-linux-x86_64.zip",
        platformLabel: "Platform",
        allPlatforms: "All platforms",
        archLabel: "Architecture",
        allArch: "All arch",
        detectedOs: "Detected OS",
        detectedArch: "Detected arch",
        runtimeTip: "Tip: verify SHA256 before running binaries.",
        recommendationTitle: "Recommended",
        recommendationLoading: "Matching recommended package for your device...",
        recommendationNone: "No package matched your device. Please choose manually.",
        recommendationHint: "Recommended for this device: {asset}",
        recommendationRelease: "Release",
        recommendationStaging: "Staging",
        releaseTitle: "Release",
        stagingTitle: "Staging",
        tagLabel: "Tag",
        assetsLabel: "Assets",
        assetHeader: "Asset",
        downloadHeader: "Download",
        shaHeader: "SHA256",
        loadingRow: "Loading...",
        noAssets: "No assets match current filters.",
        downloadBtn: "Download",
        shaBtn: "SHA256",
        recommendedBadge: "Recommended",
        loadedStatus: "Loaded release and staging manifests from {base}.",
        partialStatus: "Some manifests failed to load. Check network or publish status.",
        failedStatus: "Failed to load manifests: {error}",
      };

const pageTitle = i18n.pageTitle;
const pageDescription = i18n.pageDescription;
const downloadsBaseUrl = (import.meta.env.PUBLIC_DOWNLOADS_BASE_URL || "https://download.gproxy.leenhawk.com")
  .trim()
  .replace(/\/+$/, "");
const docsHomeHref = locale === "zh" ? "/zh/" : "/";
---

<!doctype html>
<html lang={locale === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <style is:global>
      :root {
        color-scheme: light dark;
        --bg: #f6f8fb;
        --fg: #111827;
        --muted: #6b7280;
        --panel: #ffffff;
        --panel-alt: #f8fafc;
        --border: #dbe3ef;
        --accent: #0f766e;
        --accent-2: #115e59;
        --chip: #ecfeff;
        --chip-fg: #155e75;
        --row-alt: rgba(17, 24, 39, 0.02);
        --row-hover: rgba(20, 184, 166, 0.1);
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0b1324;
          --fg: #e5e7eb;
          --muted: #94a3b8;
          --panel: #111827;
          --panel-alt: #0f172a;
          --border: #233146;
          --accent: #2dd4bf;
          --accent-2: #14b8a6;
          --chip: #0f2b33;
          --chip-fg: #67e8f9;
          --row-alt: rgba(255, 255, 255, 0.02);
          --row-hover: rgba(45, 212, 191, 0.12);
        }
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: "IBM Plex Sans", "Segoe UI", system-ui, -apple-system, sans-serif;
        color: var(--fg);
        background:
          radial-gradient(circle at 18% -10%, rgba(20, 184, 166, 0.18), transparent 28%),
          radial-gradient(circle at 86% 0%, rgba(14, 165, 233, 0.14), transparent 30%),
          var(--bg);
      }

      .wrap {
        max-width: 1240px;
        margin: 0 auto;
        padding: 2rem 1rem 3rem;
      }

      .back {
        display: inline-flex;
        margin-bottom: 1rem;
        color: var(--accent);
        font-weight: 600;
        text-decoration: none;
      }

      .hero {
        background: linear-gradient(140deg, rgba(15, 118, 110, 0.1), rgba(14, 165, 233, 0.08));
        border: 1px solid var(--border);
        border-radius: 18px;
        padding: 1.2rem 1.2rem 1.1rem;
        margin-bottom: 1rem;
      }

      .hero h1 {
        margin: 0 0 0.45rem;
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        letter-spacing: 0.02em;
      }

      .muted {
        margin: 0;
        color: var(--muted);
      }

      .status {
        margin-top: 0.7rem;
        font-size: 0.92rem;
        color: var(--muted);
      }

      .toolbar {
        display: grid;
        grid-template-columns: minmax(220px, 2fr) minmax(140px, 1fr) minmax(140px, 1fr);
        gap: 0.6rem;
        margin: 0 0 1rem;
      }

      @media (max-width: 860px) {
        .toolbar {
          grid-template-columns: 1fr;
        }
      }

      .field {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.55rem 0.65rem;
      }

      .field label {
        display: block;
        color: var(--muted);
        margin-bottom: 0.25rem;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
      }

      .field input,
      .field select {
        width: 100%;
        border: 0;
        outline: none;
        background: transparent;
        color: var(--fg);
        font-size: 0.94rem;
      }

      .runtime-info {
        margin: 0 0 1rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        border: 1px solid rgba(6, 182, 212, 0.24);
        border-radius: 999px;
        padding: 0.28rem 0.62rem;
        font-size: 0.8rem;
        color: var(--chip-fg);
        background: var(--chip);
      }

      .recommend {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        margin: 0 0 1rem;
        padding: 0.85rem 0.95rem;
      }

      .recommend h2 {
        margin: 0;
        font-size: 1.03rem;
      }

      .recommend-desc {
        margin: 0.35rem 0 0;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .recommend-list {
        margin-top: 0.65rem;
        display: grid;
        gap: 0.6rem;
      }

      .recommend-item {
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--panel-alt);
        padding: 0.6rem 0.7rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: wrap;
      }

      .channel-badge {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgba(6, 182, 212, 0.24);
        background: var(--chip);
        color: var(--chip-fg);
        border-radius: 999px;
        padding: 0.14rem 0.48rem;
        font-size: 0.72rem;
        font-weight: 700;
      }

      .recommend-meta {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        min-width: 0;
      }

      .recommend-meta .asset-name {
        overflow-wrap: anywhere;
      }

      .grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
      }

      @media (min-width: 1060px) {
        .grid {
          grid-template-columns: 1fr 1fr;
        }
      }

      .panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
      }

      .panel-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 0.8rem;
        padding: 0.86rem 0.95rem;
        border-bottom: 1px solid var(--border);
        background: var(--panel-alt);
      }

      .panel h2 {
        margin: 0;
        font-size: 1.08rem;
      }

      .meta {
        margin-top: 0.3rem;
        color: var(--muted);
        font-size: 0.88rem;
      }

      .table-wrap {
        overflow-x: visible;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        min-width: 0;
        table-layout: fixed;
      }

      th,
      td {
        text-align: left;
        border-bottom: 1px solid var(--border);
        padding: 0.82rem 0.9rem;
        font-size: 0.88rem;
        vertical-align: top;
      }

      th {
        color: var(--muted);
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        font-size: 0.73rem;
      }

      th:nth-child(1),
      td:nth-child(1) {
        width: 52%;
      }

      th:nth-child(2),
      td:nth-child(2) {
        width: 16%;
      }

      th:nth-child(3),
      td:nth-child(3) {
        width: 32%;
      }

      tbody tr:last-child td {
        border-bottom: none;
      }

      tbody tr:nth-child(even) td {
        background: var(--row-alt);
      }

      tbody tr:hover td {
        background: var(--row-hover);
      }

      tr.is-recommended td {
        background: rgba(20, 184, 166, 0.12);
      }

      .asset-line {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
      }

      .asset-name {
        font-weight: 600;
        font-size: 0.84rem;
        line-height: 1.35;
        overflow-wrap: anywhere;
      }

      .asset-badge {
        display: inline-flex;
        align-items: center;
        border-radius: 999px;
        border: 1px solid rgba(20, 184, 166, 0.35);
        background: rgba(20, 184, 166, 0.14);
        color: #0f766e;
        font-size: 0.67rem;
        font-weight: 700;
        padding: 0.08rem 0.4rem;
      }

      @media (prefers-color-scheme: dark) {
        .asset-badge {
          color: #5eead4;
        }
      }

      .cell-actions {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 7px;
        border: 1px solid var(--border);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.78rem;
        padding: 0.34rem 0.62rem;
        color: var(--fg);
        background: var(--panel-alt);
      }

      a.btn,
      a.btn:visited,
      a.btn:hover,
      a.btn:active {
        color: var(--fg);
        text-decoration: none;
      }

      .btn-primary {
        color: #ffffff;
        border-color: var(--accent);
        background: linear-gradient(140deg, var(--accent), var(--accent-2));
      }

      a.btn-primary,
      a.btn-primary:visited,
      a.btn-primary:hover,
      a.btn-primary:active {
        color: #ffffff;
      }

      .btn:hover {
        filter: brightness(1.06);
      }

      @media (max-width: 980px) {
        th,
        td {
          padding: 0.68rem 0.56rem;
        }

        th:nth-child(1),
        td:nth-child(1) {
          width: 50%;
        }

        th:nth-child(2),
        td:nth-child(2) {
          width: 16%;
        }

        th:nth-child(3),
        td:nth-child(3) {
          width: 34%;
        }

        .btn {
          padding: 0.3rem 0.48rem;
          font-size: 0.74rem;
        }
      }

      .empty {
        color: var(--muted);
        padding: 0.85rem;
      }
    </style>
  </head>
  <body>
    <main class="wrap">
      <a class="back" href={docsHomeHref}>{i18n.backToDocs}</a>
      <header class="hero">
        <h1>{pageTitle}</h1>
        <p class="muted">{pageDescription}</p>
        <p class="status" id="page-status">{i18n.loadingManifests}</p>
      </header>

      <section class="toolbar">
        <div class="field">
          <label for="asset-search">{i18n.searchLabel}</label>
          <input id="asset-search" type="search" placeholder={i18n.searchPlaceholder} />
        </div>
        <div class="field">
          <label for="platform-filter">{i18n.platformLabel}</label>
          <select id="platform-filter">
            <option value="all">{i18n.allPlatforms}</option>
            <option value="linux">Linux</option>
            <option value="macos">macOS</option>
            <option value="windows">Windows</option>
            <option value="android">Android</option>
          </select>
        </div>
        <div class="field">
          <label for="arch-filter">{i18n.archLabel}</label>
          <select id="arch-filter">
            <option value="all">{i18n.allArch}</option>
            <option value="x86_64">x86_64</option>
            <option value="aarch64">aarch64</option>
          </select>
        </div>
      </section>

      <section class="runtime-info" id="runtime-info"></section>

      <section class="recommend">
        <h2>{i18n.recommendationTitle}</h2>
        <p id="recommend-desc" class="recommend-desc">{i18n.recommendationLoading}</p>
        <div id="recommend-list" class="recommend-list"></div>
      </section>

      <section class="grid">
        <article class="panel" data-channel="release">
          <div class="panel-head">
            <div>
              <h2>{i18n.releaseTitle}</h2>
              <div class="meta">
                {i18n.tagLabel}: <strong data-tag>...</strong> · {i18n.assetsLabel}: <strong data-count>0</strong>
              </div>
            </div>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>{i18n.assetHeader}</th>
                  <th>{i18n.downloadHeader}</th>
                  <th>{i18n.shaHeader}</th>
                </tr>
              </thead>
              <tbody data-assets>
                <tr><td class="empty" colspan="3">{i18n.loadingRow}</td></tr>
              </tbody>
            </table>
          </div>
        </article>

        <article class="panel" data-channel="staging">
          <div class="panel-head">
            <div>
              <h2>{i18n.stagingTitle}</h2>
              <div class="meta">
                {i18n.tagLabel}: <strong data-tag>...</strong> · {i18n.assetsLabel}: <strong data-count>0</strong>
              </div>
            </div>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>{i18n.assetHeader}</th>
                  <th>{i18n.downloadHeader}</th>
                  <th>{i18n.shaHeader}</th>
                </tr>
              </thead>
              <tbody data-assets>
                <tr><td class="empty" colspan="3">{i18n.loadingRow}</td></tr>
              </tbody>
            </table>
          </div>
        </article>
      </section>
    </main>

    <script type="module">
      const CHANNELS = ["release", "staging"];
      const statusEl = document.getElementById("page-status");
      const searchEl = document.getElementById("asset-search");
      const platformFilterEl = document.getElementById("platform-filter");
      const archFilterEl = document.getElementById("arch-filter");
      const runtimeInfoEl = document.getElementById("runtime-info");
      const recommendListEl = document.getElementById("recommend-list");
      const recommendDescEl = document.getElementById("recommend-desc");

      const DOWNLOADS_BASE_URL = {JSON.stringify(downloadsBaseUrl)};
      const I18N = {JSON.stringify(i18n)};

      const filters = {
        q: "",
        platform: "all",
        arch: "all"
      };
      const manifests = {};
      const recommendedByChannel = {};

      function escapeHtml(input) {
        return String(input)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#39;");
      }

      function fillTemplate(template, values) {
        let output = String(template || "");
        Object.entries(values).forEach(([key, value]) => {
          output = output.replaceAll(`{${key}}`, String(value));
        });
        return output;
      }

      function parseAssetName(name) {
        const match = /^gproxy-(android|linux|macos|windows)-([a-z0-9_]+?)(-musl)?\.zip$/i.exec(
          String(name || "")
        );
        if (!match) {
          return null;
        }
        return {
          platform: match[1].toLowerCase(),
          arch: match[2].toLowerCase(),
          libc: match[3] ? "musl" : "gnu"
        };
      }

      function detectRuntime() {
        const ua = navigator.userAgent.toLowerCase();
        const platform = navigator.platform.toLowerCase();
        let os = "linux";
        if (ua.includes("android")) {
          os = "android";
        } else if (platform.includes("mac")) {
          os = "macos";
        } else if (platform.includes("win")) {
          os = "windows";
        } else if (platform.includes("linux")) {
          os = "linux";
        }

        const source = `${ua} ${platform}`;
        const arch = /aarch64|arm64|armv8/.test(source) ? "aarch64" : "x86_64";
        return { os, arch };
      }

      const runtime = detectRuntime();

      function buildRuntimeChips() {
        if (!runtimeInfoEl) return;
        runtimeInfoEl.innerHTML = `
          <span class="chip">${escapeHtml(I18N.detectedOs)}: <strong>${escapeHtml(runtime.os)}</strong></span>
          <span class="chip">${escapeHtml(I18N.detectedArch)}: <strong>${escapeHtml(runtime.arch)}</strong></span>
          <span class="chip">${escapeHtml(I18N.runtimeTip)}</span>
        `;
      }

      function matchesFilter(asset) {
        const name = String(asset?.name || "").toLowerCase();
        const meta = parseAssetName(name);
        if (filters.q && !name.includes(filters.q)) {
          return false;
        }
        if (filters.platform !== "all" && meta?.platform !== filters.platform) {
          return false;
        }
        if (filters.arch !== "all" && meta?.arch !== filters.arch) {
          return false;
        }
        return true;
      }

      function pickRecommendedAsset(assets) {
        const withMeta = (Array.isArray(assets) ? assets : [])
          .map((asset) => ({ asset, meta: parseAssetName(asset?.name) }))
          .filter((item) => item.meta);

        const candidates = withMeta.filter(
          (item) => item.meta.platform === runtime.os && item.meta.arch === runtime.arch
        );
        if (!candidates.length) return null;

        if (runtime.os === "linux") {
          for (const libc of ["gnu", "musl"]) {
            const match = candidates.find((item) => item.meta.libc === libc);
            if (match) return match.asset;
          }
        }

        return candidates[0].asset;
      }

      function computeRecommendations() {
        CHANNELS.forEach((channel) => {
          const assets = manifests[channel]?.assets || [];
          recommendedByChannel[channel] = pickRecommendedAsset(assets);
        });
      }

      function renderRecommendation() {
        if (!recommendDescEl || !recommendListEl) return;
        const lines = [];

        CHANNELS.forEach((channel) => {
          const asset = recommendedByChannel[channel];
          if (!asset) return;
          const channelLabel =
            channel === "release" ? I18N.recommendationRelease : I18N.recommendationStaging;
          const name = String(asset?.name || "unknown");
          const url = String(asset?.url || "#");
          lines.push(`
            <div class="recommend-item">
              <div class="recommend-meta">
                <span class="channel-badge">${escapeHtml(channelLabel)}</span>
                <span class="asset-name">${escapeHtml(name)}</span>
              </div>
              <div class="cell-actions">
                <a class="btn btn-primary" href="${escapeHtml(url)}">${escapeHtml(I18N.downloadBtn)}</a>
                <a class="btn" href="${escapeHtml(`${url}.sha256`)}">${escapeHtml(I18N.shaBtn)}</a>
              </div>
            </div>
          `);
        });

        if (!lines.length) {
          recommendDescEl.textContent = I18N.recommendationNone;
          recommendListEl.innerHTML = "";
          return;
        }

        const primary = recommendedByChannel.release || recommendedByChannel.staging;
        recommendDescEl.textContent = fillTemplate(I18N.recommendationHint, {
          asset: String(primary?.name || "")
        });
        recommendListEl.innerHTML = lines.join("");
      }

      function renderChannel(channel) {
        const panel = document.querySelector(`[data-channel="${channel}"]`);
        if (!panel) return;
        const tagEl = panel.querySelector("[data-tag]");
        const countEl = panel.querySelector("[data-count]");
        const bodyEl = panel.querySelector("[data-assets]");
        if (!tagEl || !countEl || !bodyEl) return;

        const manifest = manifests[channel] || {};
        const allAssets = Array.isArray(manifest.assets) ? manifest.assets : [];
        const filteredAssets = allAssets.filter(matchesFilter);
        const recommended = recommendedByChannel[channel];
        tagEl.textContent = manifest.tag ? String(manifest.tag) : "n/a";
        countEl.textContent = String(filteredAssets.length);

        if (filteredAssets.length === 0) {
          bodyEl.innerHTML = `<tr><td class="empty" colspan="3">${escapeHtml(I18N.noAssets)}</td></tr>`;
          return;
        }

        bodyEl.innerHTML = filteredAssets
          .map((asset) => {
            const name = String(asset?.name || "unknown");
            const url = String(asset?.url || "#");
            const isRecommended = Boolean(recommended && String(recommended.name) === name);
            return `
              <tr class="${isRecommended ? "is-recommended" : ""}">
                <td>
                  <div class="asset-line">
                    <span class="asset-name">${escapeHtml(name)}</span>
                    ${isRecommended ? `<span class="asset-badge">${escapeHtml(I18N.recommendedBadge)}</span>` : ""}
                  </div>
                </td>
                <td>
                  <div class="cell-actions">
                    <a class="btn btn-primary" href="${escapeHtml(url)}">${escapeHtml(I18N.downloadBtn)}</a>
                  </div>
                </td>
                <td>
                  <div class="cell-actions">
                    <a class="btn" href="${escapeHtml(`${url}.sha256`)}">${escapeHtml(I18N.shaBtn)}</a>
                  </div>
                </td>
              </tr>
            `;
          })
          .join("");
      }

      function renderAll() {
        CHANNELS.forEach((channel) => renderChannel(channel));
        renderRecommendation();
      }

      const manifestPaths = {
        release: "manifest.json",
        staging: "staging/manifest.json"
      };

      async function fetchManifest(channel) {
        const manifestPath = manifestPaths[channel];
        const url = `${DOWNLOADS_BASE_URL}/${manifestPath}?t=${Date.now()}`;
        const response = await fetch(url, { cache: "no-store" });
        if (!response.ok) {
          throw new Error(`failed to fetch ${channel} manifest: ${response.status}`);
        }
        return response.json();
      }

      function bindFilters() {
        if (searchEl) {
          searchEl.addEventListener("input", () => {
            filters.q = String(searchEl.value || "").trim().toLowerCase();
            renderAll();
          });
        }
        if (platformFilterEl) {
          platformFilterEl.addEventListener("change", () => {
            filters.platform = String(platformFilterEl.value || "all");
            renderAll();
          });
        }
        if (archFilterEl) {
          archFilterEl.addEventListener("change", () => {
            filters.arch = String(archFilterEl.value || "all");
            renderAll();
          });
        }
      }

      async function init() {
        buildRuntimeChips();
        bindFilters();

        const results = await Promise.allSettled(CHANNELS.map((channel) => fetchManifest(channel)));
        let okCount = 0;

        results.forEach((result, index) => {
          const channel = CHANNELS[index];
          if (result.status === "fulfilled") {
            okCount += 1;
            manifests[channel] = result.value;
          } else {
            manifests[channel] = { tag: "error", assets: [] };
          }
        });

        computeRecommendations();
        renderAll();

        if (statusEl) {
          statusEl.textContent =
            okCount === CHANNELS.length
              ? fillTemplate(I18N.loadedStatus, { base: DOWNLOADS_BASE_URL })
              : I18N.partialStatus;
        }
      }

      init().catch((error) => {
        if (statusEl) {
          statusEl.textContent = fillTemplate(I18N.failedStatus, {
            error: String(error?.message || error)
          });
        }
      });
    </script>
  </body>
</html>
